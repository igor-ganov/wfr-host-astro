---
import { withBase } from '../lib/base';
---

<!--
  The viewer shell is rendered on every route. It is created once on the client
  and never removed/reinserted: open/page/close are pure client-side state
  changes (history + DOM props), so a top-layer modal survives paging.
  setup-viewer.ts drives open/close and the current file from the URL.
-->
<dialog id="viewer-dialog" class="viewer-dialog" aria-label="File viewer" tabindex="-1">
  <div class="chrome">
    <span class="chrome-title" id="viewer-title"></span>
    <span class="chrome-actions">
      <button id="settings-button" type="button" aria-haspopup="dialog" aria-expanded="false">
        Settings
      </button>
      <button id="fs-button" type="button">Fullscreen</button>
      <a id="close-button" href={withBase('')} aria-label="Close viewer">Close</a>
    </span>
  </div>

  <wfr-viewer id="viewer">
    <wfr-settings-panel slot="toolbar" id="settings-panel" hidden></wfr-settings-panel>
    <wfr-viewer-nav slot="controls" id="nav"></wfr-viewer-nav>
  </wfr-viewer>
</dialog>

<script>
  import { setupViewer } from '../lib/setup-viewer';
  setupViewer();
</script>
