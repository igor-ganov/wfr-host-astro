---
import { withBase } from '../lib/base';
---

<!--
  The viewer shell is rendered on every route and created once on the client.
  The content area is a horizontal scroll-snap carousel of three panes
  (prev / current / next). A native finger swipe scrolls the track; a
  scroll-driven timeline animates the panes; the slide that lands in the
  viewport becomes the current file. setup-viewer.ts wires it all and keeps the
  URL/history/title in sync. open/page/close stay client-side (no MPA nav).
-->
<dialog id="viewer-dialog" class="viewer-dialog" aria-label="File viewer" tabindex="-1">
  <div class="chrome">
    <span class="chrome-title" id="viewer-title"></span>
    <span class="chrome-actions">
      <button id="download-button" type="button" aria-label="Download file">Download</button>
      <button id="settings-button" type="button" aria-haspopup="dialog" aria-expanded="false">
        Settings
      </button>
      <button id="fs-button" type="button">Fullscreen</button>
      <a id="close-button" href={withBase('')} aria-label="Close viewer">Close</a>
    </span>
  </div>

  <wfr-settings-panel id="settings-panel" hidden></wfr-settings-panel>

  <div class="stage">
    <div id="track" class="track" role="group" aria-label="Files" tabindex="-1">
      <section class="slide"><wfr-viewer class="pane"></wfr-viewer></section>
      <section class="slide"><wfr-viewer class="pane"></wfr-viewer></section>
      <section class="slide"><wfr-viewer class="pane"></wfr-viewer></section>
    </div>
    <wfr-viewer-nav id="nav"></wfr-viewer-nav>
  </div>
</dialog>

<script>
  import { setupViewer } from '../lib/setup-viewer';
  setupViewer();
</script>
