---
import { FILES } from '../lib/files';
import { withBase } from '../lib/base';
---

<wfr-file-grid id="file-grid" label="Sample files"></wfr-file-grid>

<noscript>
  <ul>
    {FILES.map((file) => <li><a href={withBase(`viewer/${file.id}`)}>{file.name}</a></li>)}
  </ul>
</noscript>

<script>
  import '@web-file-reader/file-grid';
  import { FILES } from '../lib/files';

  // The grid only publishes its data; activating a tile emits a bubbling,
  // composed `wfr-open` event that the viewer controller handles on `document`
  // (no navigation). Keep the <noscript> anchors as the no-JS fallback.
  const initGrid = (): void => {
    const grid = document.querySelector('wfr-file-grid');
    if (grid === null || grid.dataset.ready === '1') return;
    grid.dataset.ready = '1';
    grid.files = FILES;
  };

  initGrid();
</script>
