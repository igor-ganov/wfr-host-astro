---
import Layout from '../layouts/Layout.astro';
import Grid from '../components/Grid.astro';
import Viewer from '../components/Viewer.astro';
---

<Layout title="Web File Reader">
  <main class="page">
    <header class="masthead">
      <h1>Web File Reader</h1>
      <p>
        Headless, accessible, high-performance file reader built from a series of Lit web
        components. Pick a file to open it in the viewer.
      </p>
    </header>
    <Grid />
  </main>
  <Viewer />
</Layout>
