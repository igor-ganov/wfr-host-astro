---
import Layout from '../../layouts/Layout.astro';
import Grid from '../../components/Grid.astro';
import Viewer from '../../components/Viewer.astro';
import { FILES, fileById } from '../../lib/files';

export function getStaticPaths() {
  return FILES.map((file) => ({ params: { fileId: file.id } }));
}

const { fileId } = Astro.params;
const file = fileById(fileId);
---

<Layout title={`${file?.name ?? 'Viewer'} — Web File Reader`}>
  <main class="page">
    <header class="masthead">
      <h1>Web File Reader</h1>
    </header>
    <Grid />
  </main>
  <Viewer />
</Layout>
